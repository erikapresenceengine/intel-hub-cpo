{
  "redirects": [
    { "source": "/", "destination": "/api/dashboard", "permanent": false }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api" }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/refresh",
      "schedule": "0 11 * * *"
    }
  ]
}
